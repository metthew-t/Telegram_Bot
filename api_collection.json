{
  "info": {
    "name": "Counselling Platform API",
    "description": "Full API collection for the Counselling Platform (Telegram Bot + Web Dashboard)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/users/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"strongpass123\"\n}"
            },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"strongpass123\"\n}"
            },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Telegram Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/telegram-login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"telegram_id\": \"1234567890\",\n  \"username\": \"telegram_user\"\n}"
            },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/token/refresh/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/profile/"
          }
        }
      ]
    },
    {
      "name": "Users (Owner Only)",
      "item": [
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users/"
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users/1/"
          }
        }
      ]
    },
    {
      "name": "Cases",
      "item": [
        {
          "name": "List Cases",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/cases/"
          }
        },
        {
          "name": "Create Case",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/cases/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Need help with something\",\n  \"description\": \"Detailed description of the issue I am facing.\"\n}"
            }
          }
        },
        {
          "name": "Get Case Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/cases/1/"
          }
        },
        {
          "name": "Assign Case to Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/cases/1/assign/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"admin_id\": 2\n}"
            }
          }
        },
        {
          "name": "Close Case",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/cases/1/close/"
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "List Messages (All)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/messages/"
          }
        },
        {
          "name": "List Messages (by Case)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/messages/?case=1"
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/messages/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"case\": 1,\n  \"content\": \"Hello, I need some guidance.\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Audit Logs (Owner Only)",
      "item": [
        {
          "name": "List Audit Logs",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/audit-logs/"
          }
        }
      ]
    }
  ]
}
